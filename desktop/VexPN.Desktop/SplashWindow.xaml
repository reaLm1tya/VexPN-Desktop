<Window x:Class="VexPN.Desktop.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VexPN Loading"
        Width="260"
        Height="380"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border Background="#10131D"
            BorderBrush="#10131D"
            BorderThickness="1"
            CornerRadius="22"
            Padding="16">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Image x:Name="SplashLogo"
                   Width="170"
                   Height="170"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="Fant" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,0">
                <Image x:Name="LoadingSpinner"
                       Width="18"
                       Height="18"
                       Margin="0,1,8,0"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="Fant" />
                <TextBlock Text="Загрузка"
                           HorizontalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
